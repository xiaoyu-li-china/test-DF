{
  "name": "kindergarten-checkin-system",
  "version": "1.0.0",
  "description": "幼儿园接送实名签到系统",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "lint": "eslint src/**/*.js",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "test:verbose": "jest --runInBand --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.0",
    "sequelize": "^6.32.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.10.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "dayjs": "^1.11.9"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.48.0",
    "jest": "^29.6.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
