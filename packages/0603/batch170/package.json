{
  "name": "SplashApp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "start:remote-config": "REMOTE_CONFIG_URL=https://example.com/config.json react-native start",
    "android:remote-config": "REMOTE_CONFIG_URL=https://example.com/config.json react-native run-android",
    "ios:remote-config": "REMOTE_CONFIG_URL=https://example.com/config.json react-native run-ios",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "^0.73.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "react-native-screens": "^3.29.0",
    "react-native-safe-area-context": "^4.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.3.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "@babel/core": "^7.23.0",
    "@babel/runtime": "^7.23.0",
    "@testing-library/react-native": "^12.4.0",
    "@testing-library/jest-native": "^5.4.0",
    "jest": "^29.7.0",
    "react-test-renderer": "18.2.0"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx)"
    ]
  }
}
